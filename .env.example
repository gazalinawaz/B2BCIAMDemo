# PingOne AIC / ForgeRock Configuration
# These environment variables are required for the application to work

# Your PingOne AIC domain (without https://)
VITE_PINGONE_DOMAIN=openam-accenture-11-20.forgeblocks.com

# OAuth 2.0 Client ID from PingOne AIC
VITE_PINGONE_CLIENT_ID=BT_B2B

# Realm name in PingOne AIC
VITE_PINGONE_REALM=alpha

# Authentication tree/journey name
VITE_PINGONE_TREE=Login

# Redirect URI (must match exactly what's configured in PingOne AIC)
# For local development: http://localhost:5173
# For production: https://your-app.vercel.app
VITE_PINGONE_REDIRECT_URI=http://localhost:5173

# OAuth Scopes (configured in code, not environment variables)
# Default scopes: openid email profile fr:idm:*
# Note: All scopes must be enabled in PingOne AIC OAuth client configuration
# fr:idm:* scope is required for admin API access (user/group management)
