# Environment Variables for PingOne AIC / ForgeRock

# PingOne AIC Domain (without https://)
VITE_PINGONE_DOMAIN=openam-accenture-11-20.forgeblocks.com

# Realm name
VITE_PINGONE_REALM=alpha

# Authentication Tree/Journey name
VITE_PINGONE_TREE=Login

# OAuth Client ID
VITE_PINGONE_CLIENT_ID=your-client-id-here

# Redirect URI (update with your Vercel URL after deployment)
VITE_PINGONE_REDIRECT_URI=http://localhost:5173
